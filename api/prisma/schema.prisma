// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Gym {
  id         String   @id
  name       String
  address    String   @unique
  treasury   String
  royaltyBps Int
  approved   Boolean
  createdAt  DateTime @default(now())
}

model MembershipCache {
  id            String   @id
  tokenId       String   @unique
  gymAddress    String
  tierId        Int
  ownerAddress  String
  userAddress   String
  expiresAt     DateTime
  metadataUri   String
  updatedAt     DateTime @updatedAt

  @@index([gymAddress])
  @@index([ownerAddress])
}

model EntryEvent {
  id            String   @id @default(cuid())
  tokenId       String
  gymAddress    String
  enteredAt     DateTime @default(now())
  walletAddress String

  @@index([tokenId])
  @@index([gymAddress])
  @@index([walletAddress])
}
